{
  "name": "c-address-onboarding-bridge",
  "version": "0.1.0",
  "description": "C-Address Onboarding Bridge - Soroban smart contract + TypeScript SDK",
  "private": true,
  "workspaces": [
    "sdk"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "husky install || true",
    "estimate-deploy-cost": "ts-node scripts/estimate-deploy-cost.ts",
    "estimate:mainnet": "npm run estimate-deploy-cost -- --network mainnet",
    "estimate:testnet": "npm run estimate-deploy-cost -- --network testnet",
    "estimate:sandbox": "npm run estimate-deploy-cost -- --network sandbox"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/git": "^10.0.0",
    "@types/node": "^20.0.0",
    "commitlint": "^19.0.0",
    "husky": "^8.0.0",
    "semantic-release": "^23.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md",
          "changelogTitle": "# Changelog"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json",
            "package-lock.json",
            "sdk/package.json",
            "sdk/package-lock.json"
          ],
          "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
        }
      ],
      "@semantic-release/github"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "chore",
          "ci",
          "revert"
        ]
      ],
      "subject-case": [
        2,
        "never",
        [
          "upper-case"
        ]
      ],
      "type-case": [
        2,
        "always",
        "lower-case"
      ]
    }
  }
}
